{
  "IsEncrypted": false,
  "Values": {
    "_COMMENT": "Solo DESARROLLO local. En Azure todo va por Key Vault con Managed Identity.",

    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "python",
    "FUNCTIONS_EXTENSION_VERSION": "~4",

    "AZURE_KEY_VAULT_URI": "",

    "SQL_CONNECTION_STRING": "DRIVER={ODBC Driver 18 for SQL Server};SERVER=tu-servidor.database.windows.net;DATABASE=finance;UID=finance_svc;PWD=cambiar;Encrypt=yes;TrustServerCertificate=no;",

    "IB_CLIENT_ID": "tu_client_id",
    "IB_CLIENT_SECRET": "tu_client_secret",
    "IB_SERVICE_URL": "https://tu-empresa.com.ar/callback",
    "IB_CUSTOMER_ID": "12345678",
    "IB_GRANT_TYPE": "client_credentials",

    "_COMMENT_schedule": "NCRONTAB: '0 */10 * * * *' = cada 10 min. Ver ib_poller/function_app.py.",
    "IB_POLLER_SCHEDULE": "0 */10 * * * *",

    "IB_INCREMENTAL_LOOKBACK_DAYS": "7",

