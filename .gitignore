*.key
*.pem
*.pfx
*.p12
*.crt
secrets/
local.settings.json

# Scripts SQL con secretos resueltos (los .sql del repo tienen placeholders).
# Convención: si necesitas correr un .sql con la password real, copialo a
# create_db_user.local.sql y editá ahí; ese archivo NO se commitea.
script/*.local.sql
script/.local/

