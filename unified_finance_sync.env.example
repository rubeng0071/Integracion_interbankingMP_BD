# ============================================================
# ⚠️  NUNCA commitear este archivo con valores reales.
# Copialo a `.env` (excluido por .gitignore) y reemplazá los placeholders.
# En Azure los secretos viven en Key Vault, NO en variables de entorno.
# ============================================================

# ============================================================
# SQL Server / Azure SQL
# ============================================================
# SEC-01 — TLS obligatorio. NO usar Encrypt=no en producción.
# Para Azure SQL, dejá TrustServerCertificate=no para que se valide la cadena.
# Para SQL Server on-prem con cert self-signed válido, idem.
# Solo usá TrustServerCertificate=yes en dev local con servidor de pruebas.
SQL_CONNECTION_STRING=DRIVER={ODBC Driver 18 for SQL Server};SERVER=tu-servidor.database.windows.net;DATABASE=finance;UID=finance_svc;PWD=cambiar_aqui;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;

# ============================================================
# Mercado Pago — OAuth2 client_credentials
# ============================================================
# Panel MP → Tus integraciones → tu app → Credenciales.
# El cliente HTTP intercambia estos por un access_token vía POST /oauth/token y
# lo refresca al 80% del expires_in (6h por default).
MP_CLIENT_ID=tu_client_id
MP_CLIENT_SECRET=tu_client_secret

# OVERRIDE OPCIONAL: si se setea, el cliente lo usa directo y NO hace OAuth.
# Útil para dev local con APP_USR del panel sin registrar una app OAuth.
# En producción dejarlo vacío (los tokens APP_USR pueden no convivir bien con
# integraciones que en paralelo usan OAuth).
# MP_ACCESS_TOKEN=APP_USR_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AZ-02 — Secret de webhook MP usado para validar HMAC de notificaciones.
# Se obtiene en: panel MP → Tus integraciones → Webhooks → Configurar notificaciones
# Solo necesario para mp_webhook_function/ (Bloque 2).
MP_WEBHOOK_SECRET=cambiar_cuando_se_active_el_webhook

# ============================================================
# Interbanking — Credenciales OAuth2
# Registrar aplicación en: https://developers.interbanking.com.ar
# ============================================================
IB_CLIENT_ID=tu_client_id
IB_CLIENT_SECRET=tu_client_secret

# URL de redirección OAuth configurada en el portal (debe incluir https://)
IB_SERVICE_URL=https://tu-empresa.com.ar/callback

# Código de abonado: Administración → Bancos y cuentas → Código Cliente Interno
IB_CUSTOMER_ID=12345678

# Flujo de autenticación: "client_credentials" (default) o "password"
IB_GRANT_TYPE=client_credentials

# Solo requerido si IB_GRANT_TYPE=password
# Formato usuario: -3|numero_clave_sistema|nombre_usuario
# IB_USERNAME=-3|123456789|usuario_api
# IB_PASSWORD=tu_password_api

# ============================================================
# Interbanking — Configuración avanzada (opcional)
# ============================================================
# IB_TOKEN_URL=https://auth.interbanking.com.ar/cas/oidc/accessToken
# IB_API_BASE_URL=https://api-gw.interbanking.com.ar/api/prod/v1
# IB_SCOPE=info-financiera
# IB_PAGE_SIZE=100
# IB_TIMEOUT_SECONDS=60

# ============================================================
# Servicio — Intervalos de sincronización
# ============================================================
POLL_INTERVAL_SECONDS=600
MP_INITIAL_LOOKBACK_DAYS=365
MP_INCREMENTAL_LOOKBACK_HOURS=72
IB_INCREMENTAL_LOOKBACK_DAYS=7

# Poner true solo la primera vez para forzar carga histórica de MP
# (mp_poller_run usa MP_INITIAL_LOOKBACK_DAYS en lugar de MP_INCREMENTAL_LOOKBACK_HOURS)
MP_INITIAL_LOAD=false

# Delay entre páginas del search MP (ms). Respeta rate limit ~10 req/s del doc Rapanui.
MP_SEARCH_PAGE_DELAY_MS=200

# Schedule NCRONTAB del poller MP (cada 30 min por default).
# Formato: {sec} {min} {hour} {day} {month} {day-of-week}
# MP_POLLER_SCHEDULE=0 */30 * * * *

# ============================================================
# Salidas
# ============================================================
# CAL-08 — Carpeta donde se generan los exports a Excel.
OUTPUT_DIR=./exports

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO

# ============================================================
# Azure (vacíos en dev local; cargar en deploy)
# ============================================================
# Si AZURE_KEY_VAULT_URI está definido, los secretos se leen de Key Vault y
# se ignoran las variables de entorno con el mismo nombre.
# AZURE_KEY_VAULT_URI=https://tu-keyvault.vault.azure.net/

# Application Insights (OPS-01) — autoinstrumenta logs/exceptions/dependencies.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=https://...
